# =============================================================================
# Configuración de Base de Datos PostgreSQL
# =============================================================================
DB_NAME=campito_db
DB_USER=postgres
DB_PASSWORD=postgres123

# =============================================================================
# Configuración de pgAdmin
# =============================================================================
PGADMIN_EMAIL=admin@campito.com
PGADMIN_PASSWORD=admin123

# =============================================================================
# Configuración de OAuth2 Google
# Obtén estas credenciales en https://console.cloud.google.com/
# =============================================================================
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# =============================================================================
# AGENTE IA — GROQ (Llama 3.3 70B)
# Groq es gratuito. Obtén tu API Key en https://console.groq.com/
# =============================================================================
AGENTE_IA_ENABLED=true
GROQ_API_KEY=tu_groq_api_key

# =============================================================================
# Frontend URL (para CORS y redirects OAuth2)
# =============================================================================
FRONTEND_URL=http://localhost:3100

# =============================================================================
# Langfuse — Observabilidad del agente (opcional)
# Registrate en https://langfuse.com para obtener credenciales
# =============================================================================
LANGFUSE_PUBLIC_KEY=tu_langfuse_public_key
LANGFUSE_SECRET_KEY=tu_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# =============================================================================
# Redis — Memoria conversacional del agente (usa defaults si ejecutás con Docker)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SESSION_TTL=3600

# =============================================================================
# Backend API URL (usa default si ejecutás con Docker)
# =============================================================================
BACKEND_URL=http://backend:8080

# =============================================================================
# Perfil de Spring Boot
# =============================================================================
SPRING_PROFILES_ACTIVE=dev
